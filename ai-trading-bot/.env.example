# ============================================================
# AI Trading Bot — Environment Variables (Örnek)
# Bu dosyayı .env olarak kopyala ve gerçek değerleri gir
# cp .env.example .env
# ============================================================
# UYARI: .env dosyasını asla Git'e push etme!
# .gitignore içinde .env olduğundan emin ol.
# ============================================================

# Alpaca Paper Trading
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true

# Binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=true

# OpenAI (ChatGPT)
OPENAI_API_KEY=your_openai_api_key_here

# NewsAPI
NEWS_API_KEY=your_newsapi_key_here

# Reddit (PRAW)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=AITradingBot/1.0

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Uygulama
LOG_LEVEL=INFO
PAPER_MODE=true
